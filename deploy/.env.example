# =============================================================================
# dota2-analysis — Environment Configuration (ALL 149 variables)
# =============================================================================
# Copy what you need into deploy/.env and adjust.
# Docker Compose reads deploy/.env automatically.
#
# Durations: Go time.ParseDuration syntax — "500ms", "5s", "10m", "24h", "720h".
# Booleans: 1/0, true/false, t/f, yes/no (case-insensitive).
# CSV: comma-separated; whitespace around commas is trimmed.
# =============================================================================

# ══════════════════════════════════════════════════════════════════════════════
# APP — compose-level only (not read by Go code directly)
# ══════════════════════════════════════════════════════════════════════════════
APP_ENV=production              # dev | staging | production
LOG_LEVEL=info                  # debug | info | warn | error
HOSTNAME=default                # Docker container hostname (used in QUEUE_CONSUMER)

# Compose port mappings (not read by Go code)
REDIS_PORT=6379
POSTGRES_PORT=5432
ANALYSIS_API_PORT=8080

# ══════════════════════════════════════════════════════════════════════════════
# POSTGRES — connection & pool (ingestion + analysis)
# ══════════════════════════════════════════════════════════════════════════════
POSTGRES_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_USER=dota2
POSTGRES_PASSWORD=dota2
POSTGRES_DB=dota2
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=10m

# Test-only (not needed at runtime)
POSTGRES_TEST_DSN=               # e.g. postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# ══════════════════════════════════════════════════════════════════════════════
# REDIS — connection & pool (required by every ingestion service)
# ══════════════════════════════════════════════════════════════════════════════
REDIS_ADDRS=redis:6379          # CSV, e.g. "redis-a:6379,redis-b:6379"
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100             # 0 → default (10 * NumCPU)
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_ACTIVE_CONNS=0        # 0 = unlimited
REDIS_CONN_MAX_LIFETIME=30m
REDIS_CONN_MAX_IDLE_TIME=10m
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_READ_ONLY=false           # true + ≥2 addresses → second used for reads

# Test-only (not needed at runtime)
TEST_REDIS_ADDR=                 # e.g. localhost:6379

# ══════════════════════════════════════════════════════════════════════════════
# TELEMETRY — OpenTelemetry tracing
# ══════════════════════════════════════════════════════════════════════════════
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318   # host:port only (no http:// — SDK adds it)
OTEL_SAMPLE_RATE=1.0                      # 0.0 to 1.0

# ══════════════════════════════════════════════════════════════════════════════
# MIGRATOR — schema migrations
# ══════════════════════════════════════════════════════════════════════════════
MIGRATOR_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable
MIGRATOR_MIGRATIONS_DIR=/migrations

# ══════════════════════════════════════════════════════════════════════════════
# QUEUES — Redis Streams (ingestion pipeline)
# ══════════════════════════════════════════════════════════════════════════════
QUEUE_GROUP=workers
QUEUE_CONSUMER=                 # empty → container hostname
QUEUE_MAX_LEN=10000
QUEUE_DELETE_ON_ACK=false
QUEUE_MAX_RETRIES=3
QUEUE_MAX_BACKOFF=30s
QUEUE_FETCH_STREAM=dota2:fetch
QUEUE_FETCH_DLQ_STREAM=dota2:fetch:dlq
QUEUE_PARSE_STREAM=dota2:parse
QUEUE_PARSE_DLQ_STREAM=dota2:parse:dlq
QUEUE_ASYNC_RETRY=false
QUEUE_ASYNC_RETRY_ZSET=

# ══════════════════════════════════════════════════════════════════════════════
# PAYLOAD STORE — Redis (fetcher payloads)
# ══════════════════════════════════════════════════════════════════════════════
PAYLOAD_KEY_PREFIX=dota2:payload
PAYLOAD_DEFAULT_TTL=24h

# ══════════════════════════════════════════════════════════════════════════════
# DEDUPLICATION — Redis (seen match IDs)
# ══════════════════════════════════════════════════════════════════════════════
DEDUP_KEY_PREFIX=dota2:seen
DEDUP_TTL=24h                    # 0 = SET (no expiry)
DEDUP_USE_BLOOM=false
DEDUP_BLOOM_CAPACITY=10000000
DEDUP_BLOOM_ERROR_RATE=0.01

# ══════════════════════════════════════════════════════════════════════════════
# PROXY POOL — Redis-backed HTTP proxy rotation
# ══════════════════════════════════════════════════════════════════════════════
PROXY_KEY_PREFIX=dota2:proxy
PROXY_SEED_FILE=proxy.txt
PROXY_REMOTE_URL=https://raw.githubusercontent.com/iplocate/free-proxy-list/refs/heads/main/all-proxies.txt                # HTTP source of proxy list (refreshed on interval)
PROXY_CANARY_URL=https://api.ipify.org

PROXY_HOLD=30s                   # Lease TTL
PROXY_MIN_POOL_SIZE=0            # Below this → force refresh; 0 = disable
PROXY_MAX_FAILURES=5

PROXY_RATE_LIMIT_PER_SEC=0       # 0 = disabled
PROXY_RATE_LIMIT_BURST=0
PROXY_RATE_LIMIT_WINDOW=1s

PROXY_RANKING_INITIAL=100
PROXY_RANKING_SUCCESS=1
PROXY_RANKING_FAILURE=5          # Positive = subtracted from score on failure

PROXY_VALIDATE_TIMEOUT=10s
PROXY_VALIDATE_PARALLEL=50
PROXY_VALIDATE_CHUNK_SIZE=100
PROXY_VALIDATE_MIN_PUBLISH=0     # Min healthy proxies to publish a chunk

PROXY_REFRESH_INTERVAL=0         # 0 = one-shot
PROXY_FORCE_REFRESH_INTERVAL=1h  # Unconditional full reload; 0 = disable
PROXY_COOLDOWN_CHECK_INTERVAL=5m # How often to check expired cooldowns
PROXY_COOLDOWN_SECONDS=300       # Cooldown after max failures (seconds)

# ══════════════════════════════════════════════════════════════════════════════
# DISCOVERY — cmd/discoverer (finds matches to fetch)
# ══════════════════════════════════════════════════════════════════════════════
DISCOVERY_UPSTREAM_URL=https://api.opendota.com/api/explorer
DISCOVERY_QUERIES_DIR=/queries/matches
DISCOVERY_DEFAULT_KEY=default
DISCOVERY_WAIT_TIMEOUT=5m
DISCOVERY_HTTP_TIMEOUT=180s
DISCOVERY_INTERVAL=24h
DISCOVERY_RUN_AT_START=true
DISCOVERY_ALLOW_DIRECT=false
DISCOVERY_MAX_RETRIES=8
DISCOVERY_RETRY_BACKOFF=500ms
DISCOVERY_MIN_PROXY_POOL_SIZE=1

# Optional discovery cycles
DISCOVERY_LEAGUE_QUERIES_DIR=/queries/leagues
DISCOVERY_LEAGUE_INTERVAL=6h
DISCOVERY_TEAM_QUERIES_DIR=/queries/teams
DISCOVERY_TEAM_INTERVAL=6h
DISCOVERY_PRO_PLAYER_URL=https://api.opendota.com/api/proPlayers
DISCOVERY_PRO_PLAYER_INTERVAL=6h
DISCOVERY_HERO_STATS_URL=https://api.opendota.com/api/heroStats
DISCOVERY_HERO_STATS_INTERVAL=6h

# ══════════════════════════════════════════════════════════════════════════════
# FETCHER — cmd/fetcher (downloads match JSON)
# ══════════════════════════════════════════════════════════════════════════════
FETCHER_UPSTREAM_URL=https://api.opendota.com/api/matches   # Match ID appended by code (no %d!)
FETCHER_BATCH=10
FETCHER_BLOCK=2s
FETCHER_HTTP_TIMEOUT=30s
FETCHER_PAYLOAD_TTL=72h
FETCHER_WAIT_TIMEOUT=5m
FETCHER_MAX_PROXY_RETRIES=1
FETCHER_PROXY_BACKOFF=250ms
FETCHER_ALLOW_DIRECT=false

# ══════════════════════════════════════════════════════════════════════════════
# PARSER — cmd/parser (decodes match JSON into DB rows)
# ══════════════════════════════════════════════════════════════════════════════
PARSER_BATCH=10
PARSER_BLOCK=2s
PARSER_PARTITION_MAINTENANCE_INTERVAL=24h

# ══════════════════════════════════════════════════════════════════════════════
# ENRICHER — cmd/enricher (bootstraps reference data)
# ══════════════════════════════════════════════════════════════════════════════
ENRICH_BOOTSTRAP_PREFIX=dota2:enrich
ENRICH_BOOTSTRAP_TTL=720h        # 30 days
ENRICH_DOTACONSTANTS_BASE_URL=https://raw.githubusercontent.com/odota/dotaconstants/master/build
ENRICH_HTTP_TIMEOUT=30s
ENRICH_INTERVAL=24h
ENRICH_RUN_AT_START=true
ENRICH_ALLOW_DIRECT=false
ENRICH_WAIT_TIMEOUT=5m
ENRICH_MAX_PROXY_RETRIES=5
ENRICH_PROXY_BACKOFF=500ms
ENRICH_FORCE_BOOTSTRAP=false     # Set true to re-run all sources (bypass gate)
ENRICH_LOCAL_DIR=                # Path to local JSON for offline bootstrap

# ══════════════════════════════════════════════════════════════════════════════
# ANALYSIS — go-analysis services (api, featurizer, backtester)
# ══════════════════════════════════════════════════════════════════════════════
ANALYTICS_PATCH_ID=60            # Current Dota 2 patch ID
ANALYTICS_MODEL_DIR=./deploy/models/imitation/current
ANALYTICS_VALUE_MODEL_DIR=./deploy/models/value/current
ANALYTICS_SCORER_KIND=linear     # linear | lgbm
ANALYTICS_FEATURIZER_INTERVAL=24h
API_TOKEN=changeme               # Bearer token for /v1/* routes
API_BIND=127.0.0.1:8080
BACKTEST_PATCH_ID=               # Override patch (empty = use ANALYTICS_PATCH_ID)
BACKTEST_LIMIT=0                 # Max matches (0 = unlimited)

# ══════════════════════════════════════════════════════════════════════════════
# TRAINER — Python ML trainer (compose-only, used by compose.analysis.yml)
# ══════════════════════════════════════════════════════════════════════════════
TRAINER_POSTGRES_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable
TRAINER_PATCH_ID=60
TRAINER_ARTIFACT_DIR=/app/artifacts
TRAINER_MODEL_DIR=/models

# ML hyperparameters
TRAINER_N_ESTIMATORS=1000
TRAINER_LEARNING_RATE=0.05
TRAINER_NUM_LEAVES=31
TRAINER_MIN_CHILD_SAMPLES=20
TRAINER_EARLY_STOPPING_ROUNDS=50
TRAINER_RECALL_THRESHOLD=0.3
TRAINER_NDCG_THRESHOLD=0.4

# ══════════════════════════════════════════════════════════════════════════════
# BUILD / DEPLOY — Makefile + docker-bake (not read by Go/Python code)
# ══════════════════════════════════════════════════════════════════════════════
TAG=latest
REGISTRY=                        # Docker registry prefix
BUILDX_BAKE_ENTITLEMENTS_FS=0

# ══════════════════════════════════════════════════════════════════════════════
# DOCKER BUILD ARGS — baked into images (not runtime env vars)
# ══════════════════════════════════════════════════════════════════════════════
# VERSION=dev
# COMMIT=unknown
# GOMAXPROCS=2

# ══════════════════════════════════════════════════════════════════════════════
# SHELL SCRIPT VARS — used by tools/ scripts (not runtime env vars)
# ══════════════════════════════════════════════════════════════════════════════
# DEST=go-ingestion/assets/dotaconstants          # fetch.sh destination
# BASE_URL=https://raw.githubusercontent.com/...  # fetch.sh source
# URL=https://raw.githubusercontent.com/iplocate/free-proxy-list/refs/heads/main/all-proxies.txt  # fetch-proxies.sh source

# ══════════════════════════════════════════════════════════════════════════════
# LEGACY / UNUSED — documented but not consumed by current code
# ══════════════════════════════════════════════════════════════════════════════
# PROXY_ACQUIRE_LIMIT=0

# ══════════════════════════════════════════════════════════════════════════════
# DOCKER BUILD ARGS — baked into images (not runtime env vars)
# ══════════════════════════════════════════════════════════════════════════════
CGO_ENABLED=0                    # Disable CGo
GOOS=linux                       # Target OS
GOFLAGS=-trimpath                # Go build flags
GOMAXPROCS=2                     # Max CPU cores (ARG, default)
VERSION=dev                      # Build version (ARG, injected via ldflags)
COMMIT=unknown                   # Build commit (ARG, injected via ldflags)

# ══════════════════════════════════════════════════════════════════════════════
# SHELL SCRIPT VARS — used by tools/ scripts
# ══════════════════════════════════════════════════════════════════════════════
DEST=go-ingestion/assets/dotaconstants       # fetch.sh: destination dir
BASE_URL=https://raw.githubusercontent.com/odota/dotaconstants/master/build  # fetch.sh: source URL
URL=https://raw.githubusercontent.com/iplocate/free-proxy-list/refs/heads/main/all-proxies.txt  # fetch-proxies.sh: source URL
