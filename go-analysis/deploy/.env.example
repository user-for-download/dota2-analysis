# =============================================================================
# go-dota2-analysis — Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust as needed.
# All durations use Go's time.ParseDuration syntax: "500ms", "5s", "10m", "24h".
# =============================================================================

# -----------------------------------------------------------------------------
# Application (informational only – not used by code)
# -----------------------------------------------------------------------------
APP_ENV=dev                       # dev | staging | prod
LOG_LEVEL=info                    # debug | info | warn | error

# -----------------------------------------------------------------------------
# Postgres (shared with sibling go-dota2 project)
# -----------------------------------------------------------------------------
POSTGRES_USER=dota2
POSTGRES_PASSWORD=dota2
POSTGRES_DB=dota2
POSTGRES_PORT=5432

# DSN used by Go services (compose builds this from POSTGRES_USER/PASSWORD/DB)
POSTGRES_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable

POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=10m

# -----------------------------------------------------------------------------
# Analysis Service
# -----------------------------------------------------------------------------
ANALYTICS_PATCH_ID=72             # Current Dota 2 patch ID for filtering
ANALYTICS_SCORER_KIND=linear      # linear | lgbm
ANALYTICS_MODEL_DIR=/models/imitation/current
ANALYTICS_VALUE_MODEL_DIR=/models/value/current
ANALYTICS_FEATURIZER_INTERVAL=24h

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_TOKEN=changeme                # Bearer token for /v1/* routes
API_BIND=0.0.0.0:8080
ANALYSIS_API_PORT=8080            # Host port mapping

# -----------------------------------------------------------------------------
# Backtester
# -----------------------------------------------------------------------------
BACKTEST_PATCH_ID=                # Empty → uses ANALYTICS_PATCH_ID

# -----------------------------------------------------------------------------
# Trainer (Python, one-shot)
# -----------------------------------------------------------------------------
TRAINER_PATCH_ID=72
TRAINER_ARTIFACT_DIR=/app/artifacts
TRAINER_MODEL_DIR=/models

# -----------------------------------------------------------------------------
# OpenTelemetry (optional)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=      # e.g. jaeger:4318
OTEL_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# Build / Deploy (Makefile + compose, not read by Go)
# -----------------------------------------------------------------------------
TAG=latest
BUILDX_BAKE_ENTITLEMENTS_FS=0
