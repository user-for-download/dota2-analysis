FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates libgomp1 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY go-analysis/training/pyproject.toml .
COPY go-analysis/training/src/ src/
RUN pip install --no-cache-dir .

ENTRYPOINT ["python", "-m", "trainer"]
